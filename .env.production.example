# ══════════════════════════════════════════════════════════════
#  ConocIA — Plantilla de configuración PRODUCCIÓN
#  Copia este archivo como .env en el servidor y completa los
#  valores marcados con <REEMPLAZAR>.
# ══════════════════════════════════════════════════════════════

# ── Aplicación ────────────────────────────────────────────────
APP_NAME='ConocIA - Portal de Noticias'
APP_ENV=production
APP_KEY=<REEMPLAZAR — php artisan key:generate --show>
APP_DEBUG=false
APP_URL=https://conocia.cl
APP_MAINTENANCE_DRIVER=file

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

# ── Base de datos ─────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=conocia
DB_USERNAME=<REEMPLAZAR>
DB_PASSWORD=<REEMPLAZAR>

# ── Sesión / Cache / Queue ────────────────────────────────────
# En producción se recomienda Redis si está disponible
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.conocia.cl
SESSION_SAME_SITE=lax

QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_STORE=redis   ← activar si hay Redis

# Redis (opcional pero recomendado para performance)
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ── Correo ────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mail.conocia.cl
MAIL_PORT=587
MAIL_USERNAME=newsletter@conocia.cl
MAIL_PASSWORD=<REEMPLAZAR>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=newsletter@conocia.cl
MAIL_FROM_NAME="${APP_NAME}"

# ── Logs ──────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=error

# ── IA / APIs externas ────────────────────────────────────────
GEMINI_API_KEY=<REEMPLAZAR — Google AI Studio>
GEMINI_MODEL=gemini-2.0-flash

OPENAI_API_KEY=<REEMPLAZAR>
OPENAI_ORGANIZATION=DendrIA
OPENAI_MODEL_NAME=gpt-4-turbo

# ── Redes sociales (OAuth, opcional) ─────────────────────────
FACEBOOK_APP_ID=<REEMPLAZAR>
FACEBOOK_APP_SECRET=<REEMPLAZAR>
FACEBOOK_REDIRECT_URI=https://conocia.cl/login/facebook/callback

TWITTER_CLIENT_ID=<REEMPLAZAR>
TWITTER_CLIENT_SECRET=<REEMPLAZAR>
TWITTER_REDIRECT_URI=https://conocia.cl/login/twitter/callback

# ── Filesystem ───────────────────────────────────────────────
FILESYSTEM_DISK=public
# Para S3/R2 descomenta:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=

# ── Seguridad extra ───────────────────────────────────────────
BCRYPT_ROUNDS=12
